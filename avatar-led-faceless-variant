    <script>
        const state = JSON.parse(localStorage.getItem('fyAvatarState') || '') || {
            experience: '', niche: '', style: '', tech: '', voice: '', concept: '', nameStatus: '', customName: '', monetization: [], frequency: '', focus: [], length: '', step: 1
        };

        const metrics = {
            words: { 'Under 3 minutes': '350-450', '5-10 minutes': '900-1400', '10-15 minutes': '1500-2100', '20+ minutes': '3500+' }
        };

        const subSuggestions = {
            'Science & Technology': ['AI Tool Reviews via Avatar', 'Tech History Storytelling', 'Future Predictions'],
            'Gaming': ['Lore Explainer via 3D Host', 'Patch Notes Commentary', 'Retro Gaming Reviews'],
            'News & Politics': ['Daily Briefing Anchor', 'Geopolitics Map Explainer', 'Crypto Market Updates'],
            'default': ['Top 10 Lists with Host', 'Tutorial Series with Guide', 'Reaction Commentary']
        };

        function saveState() { localStorage.setItem('fyAvatarState', JSON.stringify(state)); }
        function getStepIndex(group) {
            const map = { experience:1, niche:2, style:3, tech:4, voice:5, concept:6, nameStatus:7, monetization:8, frequency:8, focus:9, length:9 };
            const keys = Object.keys(map);
            // Simple lookup logic for grouped steps
            if(group === 'monetization' || group === 'frequency') return 8;
            if(group === 'focus' || group === 'length') return 9;
            return map[group];
        }

        function init() {
            state.step = Number(state.step) || 1;
            goToStep(state.step);
            // Restore
            ['experience','niche','style','tech','voice','concept','nameStatus','frequency','length'].forEach(k => {
                if(state[k]) toggleSingle(k, state[k]);
            });
            if(state.nameStatus.includes('Yes') && state.customName) {
                document.getElementById('name-input-wrap').classList.replace('cond-hide', 'cond-show');
                document.getElementById('custom-name').value = state.customName;
            }
            ['monetization','focus'].forEach(k => {
                if(state[k]?.length) {
                    state[k].forEach(v => {
                        const opts = document.querySelectorAll(`[data-step="${getStepIndex(k)}"] .multi-select .option`);
                        opts.forEach(o => { if(o.dataset.value === v) o.dataset.selected = 'true'; });
                    });
                }
            });
            updateNav();
            bindEvents();
        }

        function goToStep(step) {
            state.step = step; saveState();
            document.querySelectorAll('.step-card').forEach(s => {
                const isActive = Number(s.dataset.step) === step;
                s.style.display = isActive ? 'block' : 'none';
            });
            document.getElementById('progress-fill').style.width = `${(step/9)*100}%`;
            document.getElementById('step-badge').textContent = `Step ${step}/9`;
            updateNav();
        }

        function toggleSingle(group, value) {
            state[group] = value; saveState();
            const parent = document.querySelector(`[data-step="${getStepIndex(group)}"] .single-select`);
            if(parent) {
                parent.querySelectorAll('.option').forEach(o => {
                    o.dataset.selected = o.dataset.value === value;
                });
            }
            if(group === 'nameStatus') {
                const wrap = document.getElementById('name-input-wrap');
                if(value.includes('Yes')) wrap.classList.replace('cond-hide', 'cond-show');
                else wrap.classList.replace('cond-show', 'cond-hide');
            }
            updateNav();
        }

        function updateNav() {
            const next = document.getElementById('btn-next');
            const prev = document.getElementById('btn-prev');
            
            // Validation checks
            const checks = {
                1: state.experience, 2: state.niche, 3: state.style, 
                4: state.tech, 5: state.voice, 6: state.concept, 
                7: state.nameStatus, 8: state.monetization.length && state.frequency, 
                9: state.focus.length && state.length
            };
            next.disabled = !checks[state.step];
            next.textContent = state.step === 9 ? 'Generate Blueprint' : 'Continue';
            prev.disabled = state.step === 1;
        }

        function generatePrompt() {
            const words = metrics.words[state.length] || '900-1400';
            
            // ALGORITHM CONTEXT INJECTION (ADAPTED FOR AVATAR)
            const algoContext = `ALGORITHM RULES FOR AVATARS (STRICT):
1. PARASOCIAL RESONANCE: Avatars trigger parasocial bonding faster than stock footage. Strategy must prioritize "Character Consistency" (Voice, Catchphrases, Visuals) to drive Session Resonance.
2. SEMANTIC HOST SIGNATURE: The Avatar's visual and audio pattern becomes part of the Semantic ID. Treat the character as a "Semantic Anchor".
3. RETENTION SHAPE: Avoid "Uncanny Valley" drops. Avatar expressions/gestures must align dynamically with script emphasis.
4. DEMAND WINDOWS: Use Avatar's persona to humanize abstract or high-demand topics quickly.
5. BATCHING vs BORED: While AI allows batching, scripts must include "Pattern Interrupts" unique to the Avatar character to prevent viewer fatigue across episodes.`;

            const prompt = `AVATAR-LED YOUTUBE BLUEPRINT GENERATOR
USER PROFILE:
- Niche: ${state.niche} | Avatar Style: ${state.style} | Tech: ${state.tech}
- Voice: ${state.voice} | Role: ${state.concept} | Duration: ${state.length} (${words} words)
- Upload: ${state.frequency} | Monetization: ${state.monetization.join(', ')} | Focus: ${state.focus.join(', ')}
- Name: ${state.customName || 'Needs Suggestions'}

${algoContext}

INSTRUCTIONS:
Generate a comprehensive Avatar-Led Channel Blueprint based on the user inputs and STRICTLY applying the ALGORITHM RULES. Output the following 9 sections:

1. EXECUTIVE SUMMARY: Strategy tailored to a ${state.experience} creator using ${state.tech} for a ${state.style} avatar in ${state.niche}.
2. AVATAR BIBLE & SEMANTICS:
   - Define Name, Personality, Voice, and Visual Hooks.
   - Define "Semantic IDs" (Signature look/sound) to condition the algorithm for recognition.
3. PRODUCTION PIPELINE:
   - Workflow for ${state.tech} + ${state.voice}.
   - Tools for Batching vs Real-Time.
   - "Pattern Interrupt" ideas (Gestures, Props, Background shifts) to maintain Retention Shape.
4. CONTENT STRATEGY:
   - 30-day calendar mapped to "Timing Windows" and "Demand Gaps" in ${state.niche}.
   - "Binge Loop" architecture: How to link videos via Avatar catchphrases or story threads.
5. SCRIPT BLUEPRINT:
   - Structure for ${state.length} videos utilizing "Flat Retention Line" techniques.
