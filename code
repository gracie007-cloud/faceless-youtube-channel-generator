        };

        const lengthData = {
            'Under 3 minutes': { structure: '0:00 Hook (3s) → 0:05 Core Point (1.5min) → 2:50 CTA', words: '400-500', type: 'YouTube Shorts / Ultra-short', retention: '90%+ AVD crucial' },
            '3-5 minutes': { structure: 'Hook → Problem → 3 Core Points → CTA', words: '600-900', type: 'Short-form explainers', retention: '65-80% AVD' },
            '5-10 minutes': { structure: 'Hook → Context → Deep Dive → Practical Application → CTA', words: '1,000-1,600', type: 'Standard monetizable content', retention: '50-65% AVD' },
            '10-15 minutes': { structure: 'Hook → Background → Core Analysis → Case Study → Summary → CTA', words: '1,800-2,400', type: 'Deep explainers / storytelling', retention: '40-55% AVD' },
