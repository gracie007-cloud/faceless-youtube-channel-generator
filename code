        // UI Functions
        function selectRadio(group, value) {
            state[group] = value;
            
            // Update UI
            const container = document.getElementById(group + 'Options') || document.querySelector(`input[name="${group}"]`).closest('.option-grid');
            if (!container && group === 'experience') {
                document.querySelectorAll('#experienceOptions .option-card').forEach(c => c.classList.remove('selected'));
                event.currentTarget.classList.add('selected');
            } else if (container) {
                container.querySelectorAll('.option-card').forEach(card => {
                    card.classList.remove('selected');
                    if (card.querySelector('input').value === value) card.classList.add('selected');
                });
            }

            // Handle conditional name field
            if (group === 'hasName') {
                const field = document.getElementById('nameInputField');
                if (value === 'yes') {
                    field.classList.add('active');
                    state.hasName = true;
                } else {
                    field.classList.remove('active');
                    state.hasName = false;
                    state.channelName = '';
                    document.getElementById('channelNameInput').value = '';
                }
            }
        }

        function toggleCheckbox(card, group, value) {
            const idx = state[group].indexOf(value);
            const input = card.querySelector('input');
            
            if (idx > -1) {
                state[group].splice(idx, 1);
                card.classList.remove('selected');
                input.checked = false;
            } else {
                if (group === 'channelFocus' && state[group].length >= 3) {
                    return; // Limit to 3
                }
                state[group].push(value);
                card.classList.add('selected');
                input.checked = true;
            }
        }

        function updateState(key, value) {
            state[key] = value;
        }

        function validateStep(step) {
            if (step === 1) {
                if (!state.experience) { alert('Please select your experience level'); return false; }
                if (!state.niche) { alert('Please select a niche'); return false; }
                if (!state.conceptType) { alert('Please select a content type'); return false; }
                if (state.hasName && !state.channelName.trim()) { alert('Please enter your channel name'); return false; }
                return true;
            }
            if (step === 2) {
                if (state.channelFocus.length === 0) {
                    document.getElementById('focusError').style.display = 'block';
                    return false;
                }
                if (!state.videoStyle) { alert('Please select a video style'); return false; }
                if (!state.videoLength) { alert('Please select a video length'); return false; }
                return true;
            }
            if (step === 3) {
                if (state.monetization.length === 0) { alert('Select at least one monetization method'); return false; }
                if (!state.uploadFrequency) { alert('Please select an upload frequency'); return false; }
                return true;
            }
            return true;
        }

        function nextStep() {
            if (!validateStep(currentStep)) return;
            
            document.getElementById(`step-${currentStep}`).classList.add('hidden');
            currentStep++;
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');
            document.getElementById(`step-${currentStep}`).classList.add('fade-in');
            updateProgress();
        }

        function prevStep() {
            document.getElementById(`step-${currentStep}`).classList.add('hidden');
            currentStep--;
            document.getElementById(`step-${currentStep}`).classList.remove('hidden');
            document.getElementById(`step-${currentStep}`).classList.add('fade-in');
            updateProgress();
        }

        function updateProgress() {
            const fill = document.getElementById('progressFill');
            const percent = ((currentStep - 1) / 2) * 100;
            fill.style.width = percent + '%';
            
            document.querySelectorAll('.step-indicator').forEach((el, idx) => {
                el.classList.remove('active', 'completed');
                if (idx + 1 < currentStep) el.classList.add('completed');
                if (idx + 1 === currentStep) el.classList.add('active');
            });
        }

        // Generator Functions
        function getSubNiche() {
            if (!state.niche || !nicheData[state.niche]) return 'General Explainer';
            const subs = nicheData[state.niche].subs;
            // Pick based on concept
            const conceptMap = {
                'How-to': 0, 'Tips': 1, 'Activity': 2, 'Science experiment': 3,
                'Concept overview': 1, 'Problem walkthrough': 0, 'Real life application': 2,
                'Lecture': 3, 'Other': 1, 'Not sure': 1
            };
            const idx = conceptMap[state.conceptType] || 1;
            return subs[idx % subs.length];
        }

        function generateNameIdeas() {
            const prefixes = ['Silent', 'Hidden', 'Voiceless', 'Anon', 'Ghost', 'Faceless', 'Cipher', 'Echo', 'Blank', 'Void', 'Phantom', 'Static'];
            const roots = {
                'Autos & Vehicles': ['Shift', 'Torque', 'Drift', 'Motor', 'Gear'],
                'Comedy': ['Jester', 'Bit', 'Satire', 'Punch', 'Gag'],
