        };

        const styleData = {
            'Data & Analysis': { tone: 'Clinical, authoritative, evidence-driven', visual: 'Charts, infographics, data visualizations, stock footage with analytical overlays, minimal text-on-screen' },
            'Documentary Style': { tone: 'Narrative, immersive, investigative', visual: 'Archival footage, cinematic B-roll, chapter markers, color graded sequences, slow pans' },
