type UploadFrequency = "1-2" | "3-5" | "biweekly" | "daily" | "monthly";
type Monetization = "affiliate" | "sponsorships" | "memberships" | "merchandise" | "courses" | "digital" | "adsense";

interface ChannelBlueprint {
  experience: ExperienceLevel | null;
  niche: Niche | null;
  contentIdea: ContentIdea | null;
  hasChannelName: boolean;
  channelName: string;
  monetization: Monetization[];
  uploadFrequency: UploadFrequency | null;
  videoLength: VideoLength | null;
  videoStyle: VideoStyle[];
  channelFocus: string[];
}

const nicheLabels: Record<Niche, string> = {
  autos: "Autos & Vehicles",
  comedy: "Comedy",
  education: "Education",
  entertainment: "Entertainment",
  film: "Film & Animation",
  gaming: "Gaming",
  howto: "How-to & Style",
  music: "Music",
  news: "News & Politics",
  nonprofits: "Nonprofits & Activism",
  people: "People & Blogs",
  pets: "Pets & Animals",
  science: "Science & Technology",
  sports: "Sports",
  travel: "Travel & Events",
};

const contentIdeaLabels: Record<ContentIdea, string> = {
  activity: "Activity",
  concept: "Concept overview",
  howto: "How-to",
  lecture: "Lecture",
  problem: "Problem walkthrough",
  reallife: "Real life application",
  science: "Science experiment",
  tips: "Tips",
  other: "Other",
  unsure: "Not sure (let the AI decide)",
};

const monetizationLabels: Record<Monetization, string> = {
  affiliate: "Affiliate Marketing",
  sponsorships: "Brand Sponsorships",
  memberships: "Channel Memberships",
  merchandise: "Merchandise",
  courses: "Online Courses",
  digital: "Selling Digital Products",
  adsense: "YouTube AdSense",
};

const videoLengthLabels: Record<VideoLength, string> = {
  1: "3-5 minutes (short and punchy)",
  2: "5-10 minutes (sweet spot for most niches)",
  3: "10-15 minutes (in-depth but digestible)",
  4: "15-20 minutes (deep dives and tutorials)",
  5: "20+ minutes (long-form documentary or masterclass style)",
  6: "Under 3 minutes (YouTube Shorts/Ultra-short)",
};

const videoStyleLabels: Record<VideoStyle, string> = {
  data: "Data & Analysis: Research-driven, deep dives, comparisons",
  documentary: "Documentary Style: Long-form, narrative-driven, investigative",
  educational: "Educational: Teaching, explaining, how-to-guides",
  entertaining: "Entertaining: Fun, engaging, storytelling",
  motivational: "Motivational: Inspiring mindset, success stories",
  news: "News & Commentary: Reacting to trends, breaking down current events",
  quicktips: "Quick-Tips & Hacks: Short, punchy, actionable advice",
  reviews: "Reviews & Recommendations: Product reviews, tool breakdowns, top 10 lists",
};

const channelFocusOptions = [
  "Analysis",
  "Beginner-Friendly",
  "Deep Dives",
  "Psychology and Sentiments",
  "Recap & Quick Briefs",
  "Report Summaries",
  "Sector/Industry Updates",
  "Spotlights",
  "Strategies",
  "Trends",
];

export default function FacelessYouTubeBlueprintApp() {
  const [currentStep, setCurrentStep] = useState(1);
  const [blueprint, setBlueprint] = useState<ChannelBlueprint>({
    experience: null,
    niche: null,
    contentIdea: null,
    hasChannelName: false,
    channelName: "",
    monetization: [],
    uploadFrequency: null,
    videoLength: null,
    videoStyle: [],
    channelFocus: [],
  });
  const [generatedBlueprint, setGeneratedBlueprint] = useState<string | null>(null);
  const [copied, setCopied] = useState(false);

  const totalSteps = 7;

  const handleExperienceSelect = (exp: ExperienceLevel) => {
    setBlueprint({ ...blueprint, experience: exp });
  };

  const handleNicheSelect = (niche: Niche) => {
    setBlueprint({ ...blueprint, niche });
  };

  const handleContentIdeaSelect = (idea: ContentIdea) => {
    setBlueprint({ ...blueprint, contentIdea: idea });
  };

  const handleHasChannelName = (has: boolean) => {
    setBlueprint({ ...blueprint, hasChannelName: has });
  };

  const handleChannelNameChange = (name: string) => {
    setBlueprint({ ...blueprint, channelName: name });
  };

  const handleMonetizationToggle = (mon: Monetization) => {
    const newMonetization = blueprint.monetization.includes(mon)
      ? blueprint.monetization.filter((m) => m !== mon)
      : [...blueprint.monetization, mon];
    setBlueprint({ ...blueprint, monetization: newMonetization });
  };

  const handleUploadFrequencySelect = (freq: UploadFrequency) => {
    setBlueprint({ ...blueprint, uploadFrequency: freq });
  };

  const handleVideoLengthSelect = (len: VideoLength) => {
    setBlueprint({ ...blueprint, videoLength: len });
  };

  const handleVideoStyleToggle = (style: VideoStyle) => {
    const newStyles = blueprint.videoStyle.includes(style)
      ? blueprint.videoStyle.filter((s) => s !== style)
      : [...blueprint.videoStyle, style];
    setBlueprint({ ...blueprint, videoStyle: newStyles });
  };

  const handleChannelFocusToggle = (focus: string) => {
    const newFocus = blueprint.channelFocus.includes(focus)
      ? blueprint.channelFocus.filter((f) => f !== focus)
      : [...blueprint.channelFocus, focus];
    setBlueprint({ ...blueprint, channelFocus: newFocus });
  };

  const generateBlueprint = () => {
    const prompt = `FACLESS YOUTUBE CHANNEL BLUEPRINT GENERATOR

USER PROFILE:
- Experience Level: ${blueprint.experience?.toUpperCase()}
- Primary Niche: ${blueprint.niche ? nicheLabels[blueprint.niche] : "TBD"}
- Content Format: ${blueprint.contentIdea ? contentIdeaLabels[blueprint.contentIdea] : "TBD"}
- Channel Name: ${blueprint.hasChannelName ? blueprint.channelName : "Needs suggestion"}
- Monetization Strategies: ${blueprint.monetization.map((m) => monetizationLabels[m]).join(", ")}
- Upload Frequency: ${blueprint.uploadFrequency} times per week
- Average Video Length: ${blueprint.videoLength ? videoLengthLabels[blueprint.videoLength] : "TBD"}
- Video Styles: ${blueprint.videoStyle.map((s) => videoStyleLabels[s]).join("; ")}
- Channel Focus Areas: ${blueprint.channelFocus.join(", ")}

Generate a comprehensive faceless YouTube channel blueprint including:

1. CHANNEL BRANDING STRATEGY
   - Brand name suggestions (if needed)
   - Logo and visual identity guidelines
   - Channel trailer concept
   - Color palette recommendations
   - Typography for thumbnails

2. NICHE & CONTENT STRATEGY
   - Detailed content pillars
   - Sub-niche opportunities
   - Target audience persona
   - Content calendar framework
   - Video topic ideas (10 initial concepts)

3. VIDEO PRODUCTION BLUEPRINT
   - Recommended faceless video formats
   - Voiceover setup and tools
   - Scriptwriting framework
   - Video editing software recommendations
   - Thumbnail design strategy
   - Background music and SFX suggestions

4. SEO & DISCOVERY STRATEGY
   - Keyword research methodology
   - Title optimization formulas
   - Description templates
   - Tag strategy
   - Hashtag recommendations

5. MONETIZATION ROADMAP
   - Phase 1 (0-10K subscribers): Early monetization tactics
   - Phase 2 (10K-100K subscribers): Scaling revenue
   - Phase 3 (100K+ subscribers): Advanced strategies
   - Revenue projection estimates
   - Alternative income streams

6. GROWTH STRATEGY
   - Community building approach
   - Cross-platform promotion
   - Collaboration strategy
   - Analytics tracking and optimization
   - Algorithm understanding

7. TECHNICAL SETUP GUIDE
   - Equipment recommendations
   - Recording workspace setup
   - Software stack
   - Backup and organization system

8. LAUNCH CHECKLIST
   - Pre-launch tasks (Week -4 to -1)
   - Launch week tasks
   - Post-launch optimization (Week 1-4)

Format this as an actionable, detailed roadmap with specific recommendations based on the user's experience level and chosen parameters.`;

    setGeneratedBlueprint(prompt);
    setCurrentStep(8);
  };

  const copyToClipboard = () => {
    if (generatedBlueprint) {
      navigator.clipboard.writeText(generatedBlueprint);
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    }
  };

  const renderProgressBar = () => (
    <div className="w-full mb-8">
      <div className="flex justify-between mb-2">
        {[...Array(totalSteps)].map((_, i) => (
          <div
            key={i}
            className={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold ${
              i + 1 <= currentStep
                ? "bg-blue-600 text-white"
                : "bg-gray-200 text-gray-500"
            }`}
          >
            {i + 1}
          </div>
        ))}
      </div>
      <div className="w-full bg-gray-200 rounded-full h-2">
        <div
          className="bg-blue-600 h-2 rounded-full transition-all duration-300"
          style={{ width: `${(currentStep / totalSteps) * 100}%` }}
        />
      </div>
    </div>
  );

  const renderStep1 = () => (
    <div className="space-y-4">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        What's your current experience with starting a faceless YouTube channel?
      </h2>
      <p className="text-gray-600 mb-6">Select the option that best describes your level</p>
      <div className="space-y-3">
        {(["beginner", "intermediate", "advanced"] as ExperienceLevel[]).map((exp) => (
          <button
            key={exp}
            onClick={() => handleExperienceSelect(exp)}
            className={`w-full p-4 rounded-lg border-2 text-left transition-all ${
              blueprint.experience === exp
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-semibold capitalize">{exp}</span>
            <p className="text-sm text-gray-500 mt-1">
              {exp === "beginner" && "New to YouTube and faceless content creation"}
              {exp === "intermediate" && "Some experience with content creation"}
              {exp === "advanced" && "Experienced creator looking to optimize"}
            </p>
          </button>
        ))}
      </div>
    </div>
  );

  const renderStep2 = () => (
    <div className="space-y-4">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        What niche do you have knowledge in?
      </h2>
      <p className="text-gray-600 mb-6">Choose the category that best fits your expertise</p>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
        {(Object.keys(nicheLabels) as Niche[]).map((niche) => (
          <button
            key={niche}
            onClick={() => handleNicheSelect(niche)}
            className={`p-4 rounded-lg border-2 text-left transition-all ${
              blueprint.niche === niche
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-medium">{nicheLabels[niche]}</span>
          </button>
        ))}
      </div>
    </div>
  );

  const renderStep3 = () => (
    <div className="space-y-4">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        Do you have an idea of what your channel will be about?
      </h2>
      <p className="text-gray-600 mb-6">Select your primary content format</p>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
        {(Object.keys(contentIdeaLabels) as ContentIdea[]).map((idea) => (
          <button
            key={idea}
            onClick={() => handleContentIdeaSelect(idea)}
            className={`p-4 rounded-lg border-2 text-left transition-all ${
              blueprint.contentIdea === idea
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-medium">{contentIdeaLabels[idea]}</span>
          </button>
        ))}
      </div>
    </div>
  );

  const renderStep4 = () => (
    <div className="space-y-4">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        Do you already have a name for your channel?
      </h2>
      <p className="text-gray-600 mb-6">Let us know if you need help with naming</p>
      <div className="space-y-4">
        <div className="flex gap-4">
          <button
            onClick={() => handleHasChannelName(true)}
            className={`flex-1 p-6 rounded-lg border-2 text-center transition-all ${
              blueprint.hasChannelName
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-semibold text-lg">Yes, I have a name</span>
          </button>
          <button
            onClick={() => handleHasChannelName(false)}
            className={`flex-1 p-6 rounded-lg border-2 text-center transition-all ${
              !blueprint.hasChannelName
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-semibold text-lg">No, I need suggestions</span>
          </button>
        </div>
        {blueprint.hasChannelName && (
          <input
            type="text"
            placeholder="Enter your channel name"
            value={blueprint.channelName}
            onChange={(e) => handleChannelNameChange(e.target.value)}
            className="w-full p-4 border-2 border-gray-200 rounded-lg focus:border-blue-500 focus:outline-none"
          />
        )}
      </div>
    </div>
  );

  const renderStep5 = () => (
    <div className="space-y-4">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        How do you plan to monetize your channel?
      </h2>
      <p className="text-gray-600 mb-6">Select all that apply</p>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
        {(Object.keys(monetizationLabels) as Monetization[]).map((mon) => (
          <button
            key={mon}
            onClick={() => handleMonetizationToggle(mon)}
            className={`p-4 rounded-lg border-2 text-left transition-all ${
              blueprint.monetization.includes(mon)
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-medium">{monetizationLabels[mon]}</span>
            {blueprint.monetization.includes(mon) && (
              <span className="ml-2 text-blue-600">✓</span>
            )}
          </button>
        ))}
      </div>
    </div>
  );

  const renderStep6 = () => (
    <div className="space-y-4">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        How often do you plan to upload videos?
      </h2>
      <p className="text-gray-600 mb-6">Choose your upload schedule</p>
      <div className="space-y-3">
        {([
          { value: "daily", label: "Daily", desc: "Maximum exposure, high commitment" },
          { value: "1-2", label: "1-2 times per week", desc: "Balanced approach, sustainable" },
          { value: "3-5", label: "3-5 times per week", desc: "Heavy output, fast growth potential" },
          { value: "biweekly", label: "Bi-weekly", desc: "Lower commitment, more time per video" },
          { value: "monthly", label: "Monthly", desc: "Minimal commitment, quality focus" },
        ] as { value: UploadFrequency; label: string; desc: string }[]).map((freq) => (
          <button
            key={freq.value}
            onClick={() => handleUploadFrequencySelect(freq.value)}
            className={`w-full p-4 rounded-lg border-2 text-left transition-all ${
              blueprint.uploadFrequency === freq.value
                ? "border-blue-600 bg-blue-50"
                : "border-gray-200 hover:border-blue-300"
            }`}
          >
            <span className="font-semibold">{freq.label}</span>
            <p className="text-sm text-gray-500 mt-1">{freq.desc}</p>
          </button>
        ))}
      </div>
    </div>
  );

  const renderStep7 = () => (
    <div className="space-y-6">
      <h2 className="text-2xl font-bold text-gray-800 mb-2">
        Customize Your Video Strategy
      </h2>
      <p className="text-gray-600 mb-6">Help us understand your content preferences</p>

      <div className="space-y-6">
        <div>
          <h3 className="font-semibold text-lg mb-3">Video Length Preference</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
            {(Object.keys(videoLengthLabels) as VideoLength[]).map((len) => (
              <button
                key={len}
                onClick={() => handleVideoLengthSelect(len)}
                className={`p-3 rounded-lg border-2 text-left transition-all text-sm ${
                  blueprint.videoLength === len
                    ? "border-blue-600 bg-blue-50"
                    : "border-gray-200 hover:border-blue-300"
                }`}
              >
                {videoLengthLabels[len]}
              </button>
            ))}
          </div>
        </div>

        <div>
          <h3 className="font-semibold text-lg mb-3">Video Style (select multiple)</h3>
          <div className="grid grid-cols-1 gap-3">
            {(Object.keys(videoStyleLabels) as VideoStyle[]).map((style) => (
              <button
                key={style}
                onClick={() => handleVideoStyleToggle(style)}
                className={`p-4 rounded-lg border-2 text-left transition-all ${
                  blueprint.videoStyle.includes(style)
                    ? "border-blue-600 bg-blue-50"
                    : "border-gray-200 hover:border-blue-300"
                }`}
              >
                <span className="font-medium">{videoStyleLabels[style]}</span>
                {blueprint.videoStyle.includes(style) && (
                  <span className="ml-2 text-blue-600">✓</span>
                )}
              </button>
            ))}
          </div>
        </div>

        <div>
          <h3 className="font-semibold text-lg mb-3">Channel Focus Areas (select multiple)</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
            {channelFocusOptions.map((focus) => (
              <button
                key={focus}
                onClick={() => handleChannelFocusToggle(focus)}
                className={`p-4 rounded-lg border-2 text-left transition-all ${
                  blueprint.channelFocus.includes(focus)
                    ? "border-blue-600 bg-blue-50"
                    : "border-gray-200 hover:border-blue-300"
                }`}
              >
                <span className="font-medium">{focus}</span>
                {blueprint.channelFocus.includes(focus) && (
                  <span className="ml-2 text-blue-600">✓</span>
                )}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  );

  const renderStep8 = () => (
    <div className="space-y-6">
      <div className="text-center mb-6">
        <h2 className="text-3xl font-bold text-gray-800 mb-2">Your Faceless YouTube Blueprint</h2>
        <p className="text-gray-600">Follow the instructions below to build your faceless YouTube channel</p>
      </div>

      <div className="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
        <h3 className="font-bold text-blue-800 mb-3">📋 Instructions:</h3>
        <ol className="list-decimal list-inside space-y-2 text-blue-700">
          <li>Click "Copy Full Prompt" below</li>
          <li>Open a new 'Notebook' in NotebookLM</li>
          <li>Paste the generated prompt into the source box</li>
          <li>The AI will generate your YouTube channel blueprint</li>
        </ol>
      </div>

      <div className="bg-gray-900 rounded-lg p-6 max-h-96 overflow-y-auto">
        <pre className="text-green-400 text-sm whitespace-pre-wrap font-mono">
          {generatedBlueprint}
        </pre>
      </div>

      <button
        onClick={copyToClipboard}
        className={`w-full py-4 rounded-lg font-semibold text-lg transition-all ${
          copied
            ? "bg-green-600 text-white"
            : "bg-blue-600 text-white hover:bg-blue-700"
        }`}
      >
        {copied ? "✓ Copied to Clipboard!" : "📋 Copy Full Prompt"}
      </button>

      <button
        onClick={() => {
          setCurrentStep(1);
          setGeneratedBlueprint(null);
        }}
        className="w-full py-3 rounded-lg border-2 border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-all"
      >
        Start Over
      </button>
    </div>
  );

  const renderCurrentStep = () => {
    switch (currentStep) {
      case 1:
        return renderStep1();
      case 2:
        return renderStep2();
      case 3:
        return renderStep3();
      case 4:
        return renderStep4();
      case 5:
        return renderStep5();
      case 6:
        return renderStep6();
      case 7:
        return renderStep7();
      case 8:
        return renderStep8();
      default:
        return null;
    }
  };

  const canProceed = () => {
    switch (currentStep) {
      case 1:
        return blueprint.experience !== null;
      case 2:
        return blueprint.niche !== null;
      case 3:
        return blueprint.contentIdea !== null;
      case 4:
        return blueprint.hasChannelName ? blueprint.channelName.length > 0 : true;
      case 5:
        return blueprint.monetization.length > 0;
      case 6:
        return blueprint.uploadFrequency !== null;
      case 7:
        return blueprint.videoLength !== null && blueprint.videoStyle.length > 0 && blueprint.channelFocus.length > 0;
      default:
        return true;
    }
  };

  const handleNext = () => {
    if (currentStep < totalSteps) {
      setCurrentStep(currentStep + 1);
    } else {
      generateBlueprint();
    }
  };

  const handleBack = () => {
    if (currentStep > 1) {
      setCurrentStep(currentStep - 1);
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 py-8 px-4">
      <div className="max-w-3xl mx-auto">
        <div className="bg-white rounded-2xl shadow-xl p-8">
          <div className="text-center mb-8">
            <h1 className="text-3xl font-bold text-gray-800 mb-2">
              🎬 Faceless YouTube Channel Blueprint Generator
            </h1>
            <p className="text-gray-600">
              Answer a few questions to get your personalized strategy
            </p>
          </div>

          {currentStep < 8 && renderProgressBar()}

          <div className="min-h-96">
            {renderCurrentStep()}
          </div>

          {currentStep < 8 && (
            <div className="flex gap-4 mt-8">
              {currentStep > 1 && (
                <button
                  onClick={handleBack}
                  className="flex-1 py-3 rounded-lg border-2 border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-all"
                >
                  Back
                </button>
              )}
              <button
                onClick={handleNext}
                disabled={!canProceed()}
                className={`flex-1 py-3 rounded-lg font-semibold transition-all ${
                  canProceed()
                    ? "bg-blue-600 text-white hover:bg-blue-700"
                    : "bg-gray-300 text-gray-500 cursor-not-allowed"
                }`}
              >
                {currentStep === totalSteps ? "Generate Blueprint" : "Continue"}
              </button>
            </div>
          )}
        </div>

        <div className="mt-6 text-center text-gray-500 text-sm">
          <p>Built for faceless content creators worldwide 🌐</p>
        </div>
      </div>
    </div>
  );
}
