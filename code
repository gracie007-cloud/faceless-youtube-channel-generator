        };

        const uploadData = {
            'Daily': { weekly: 7, model: 'Aggressive growth; requires template workflows and batching', risk: 'Burnout risk high for solo creators' },
            '3-5 times per week': { weekly: 4, model: 'High velocity; strong algorithmic signal', risk: 'Requires content pipeline and possible VA help' },
